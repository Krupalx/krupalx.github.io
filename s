<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Niv's 9th Birthday Party 🎉</title>
<link href="https://fonts.googleapis.com/css2?family=Boogaloo&family=Nunito:wght@400;700;900;800&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }

:root {
  --pink: #ff4d8d;
  --yellow: #FFE033;
  --purple: #7B2FBE;
  --teal: #00C9B1;
  --orange: #FF7733;
  --bg: #0d0820;
}

body {
  font-family: 'Nunito', sans-serif;
  background: var(--bg);
  color: #fff;
  overflow-x: hidden;
  cursor: default;
}

/* ── CONFETTI CANVAS ── */
#confetti-canvas {
  position: fixed; inset: 0;
  pointer-events: none;
  z-index: 999;
}

/* ── LANG TOGGLE ── */
.lang-toggle {
  position: fixed; top: 14px; right: 14px; z-index: 500;
  display: flex; gap: 6px;
}
.lang-btn {
  background: rgba(255,255,255,0.12);
  border: 1.5px solid rgba(255,255,255,0.25);
  color: #fff;
  padding: 6px 14px;
  border-radius: 20px;
  font-family: 'Nunito', sans-serif;
  font-weight: 800;
  font-size: 12px;
  cursor: pointer;
  transition: all .2s;
  letter-spacing: .5px;
}
.lang-btn.active {
  background: var(--yellow);
  color: #111;
  border-color: var(--yellow);
}

/* ── HERO ── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 60px 24px 40px;
  overflow: hidden;
}

.hero-bg {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 0%, rgba(123,47,190,0.5) 0%, transparent 70%),
    radial-gradient(ellipse 60% 50% at 80% 80%, rgba(255,77,141,0.35) 0%, transparent 60%),
    radial-gradient(ellipse 50% 40% at 10% 60%, rgba(0,201,177,0.25) 0%, transparent 60%),
    var(--bg);
}

/* Floating shapes */
.shape {
  position: absolute;
  border-radius: 50%;
  animation: floatShape ease-in-out infinite;
  opacity: 0.15;
}
@keyframes floatShape {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-30px) rotate(180deg); }
}

.hero-tag {
  position: relative;
  display: inline-block;
  background: var(--pink);
  color: #fff;
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  padding: 6px 18px;
  border-radius: 20px;
  margin-bottom: 16px;
  animation: pop 0.5s cubic-bezier(.36,.07,.19,.97);
}
@keyframes pop {
  0% { transform: scale(0); opacity: 0; }
  70% { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}

.hero-name {
  position: relative;
  font-family: 'Boogaloo', cursive;
  font-size: clamp(72px, 22vw, 140px);
  line-height: 0.9;
  background: linear-gradient(135deg, var(--yellow) 0%, var(--orange) 50%, var(--pink) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 30px rgba(255,224,51,0.4));
  animation: nameIn 0.7s 0.1s cubic-bezier(.36,.07,.19,.97) both;
}
@keyframes nameIn {
  0% { transform: translateY(40px) scale(0.8); opacity: 0; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}

.age-ring {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 90px; height: 90px;
  margin: 16px auto;
  animation: spin3d 6s linear infinite;
}
@keyframes spin3d {
  0% { transform: rotateY(0deg); }
  100% { transform: rotateY(360deg); }
}
.age-ring-inner {
  position: absolute; inset: 0;
  border-radius: 50%;
  border: 4px solid transparent;
  background: linear-gradient(var(--bg), var(--bg)) padding-box,
    linear-gradient(135deg, var(--yellow), var(--pink), var(--teal)) border-box;
  animation: none;
}
.age-num {
  font-family: 'Boogaloo', cursive;
  font-size: 52px;
  color: var(--yellow);
  position: relative;
  z-index: 1;
  animation: none;
  -webkit-text-fill-color: var(--yellow);
}

.hero-sub {
  position: relative;
  font-size: clamp(15px, 4vw, 20px);
  font-weight: 700;
  color: rgba(255,255,255,0.75);
  margin-top: 8px;
  letter-spacing: 0.3px;
}

.scroll-hint {
  position: absolute;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 4px;
  opacity: 0.4;
  animation: bounce 1.5s infinite;
}
@keyframes bounce {
  0%,100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(8px); }
}
.scroll-hint span { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; }
.scroll-hint svg { width: 20px; }

/* ── SLIDESHOW ── */
.slideshow-section {
  padding: 60px 20px;
  max-width: 900px;
  margin: 0 auto;
}

.section-label {
  text-align: center;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 8px;
}

.section-title {
  text-align: center;
  font-family: 'Boogaloo', cursive;
  font-size: clamp(32px, 8vw, 54px);
  color: #fff;
  margin-bottom: 32px;
  line-height: 1.1;
}

.slideshow {
  position: relative;
  border-radius: 24px;
  overflow: hidden;
  background: #111;
  aspect-ratio: 3/4;
  max-height: 75vh;
  max-width: 420px;
  margin: 0 auto;
}

.slide {
  position: absolute; inset: 0;
  opacity: 0;
  transition: opacity 0.7s ease;
  display: flex; align-items: center; justify-content: center;
}
.slide.active { opacity: 1; }
.slide img {
  width: 100%; height: 100%;
  object-fit: contain;
  background: #111;
}

.slide-caption {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 40px 20px 18px;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  font-size: 13px;
  font-weight: 700;
  color: rgba(255,255,255,0.7);
  text-align: center;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.slide-nav {
  display: flex; justify-content: center; gap: 8px; margin-top: 16px;
}
.dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  cursor: pointer;
  transition: all .3s;
  border: none;
}
.dot.active { background: var(--yellow); transform: scale(1.4); }

.slide-arrows {
  position: absolute;
  top: 50%; transform: translateY(-50%);
  width: 100%;
  display: flex;
  justify-content: space-between;
  padding: 0 12px;
  pointer-events: none;
  z-index: 10;
}
.arrow-btn {
  pointer-events: all;
  background: rgba(255,255,255,0.15);
  border: none;
  color: white;
  width: 40px; height: 40px;
  border-radius: 50%;
  font-size: 18px;
  cursor: pointer;
  backdrop-filter: blur(4px);
  transition: background .2s;
  display: flex; align-items: center; justify-content: center;
}
.arrow-btn:hover { background: rgba(255,255,255,0.3); }

/* ── PARTY DETAILS ── */
.details-section {
  padding: 0 20px 60px;
  max-width: 700px;
  margin: 0 auto;
}

.details-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
  margin-bottom: 14px;
}

.detail-card {
  background: rgba(255,255,255,0.06);
  border: 1.5px solid rgba(255,255,255,0.1);
  border-radius: 20px;
  padding: 22px 18px;
  text-align: center;
  transition: transform .2s, border-color .2s;
  position: relative;
  overflow: hidden;
}
.detail-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 0%, rgba(255,255,255,0.04), transparent 70%);
  pointer-events: none;
}
.detail-card:hover {
  transform: translateY(-3px);
  border-color: rgba(255,255,255,0.22);
}
.detail-card.accent-pink { border-color: rgba(255,77,141,0.4); }
.detail-card.accent-yellow { border-color: rgba(255,224,51,0.4); }
.detail-card.accent-teal { border-color: rgba(0,201,177,0.4); }
.detail-card.accent-purple { border-color: rgba(123,47,190,0.4); }
.detail-card.full { grid-column: 1 / -1; }

.detail-icon { font-size: 32px; margin-bottom: 10px; }
.detail-label {
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.detail-label.pink { color: var(--pink); }
.detail-label.yellow { color: var(--yellow); }
.detail-label.teal { color: var(--teal); }
.detail-label.purple { color: #b07bff; }
.detail-value {
  font-size: 16px;
  font-weight: 800;
  line-height: 1.4;
  color: #fff;
}
.detail-value.big {
  font-family: 'Boogaloo', cursive;
  font-size: 22px;
}

.map-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 10px;
  background: var(--teal);
  color: #0d0820;
  font-weight: 900;
  font-size: 13px;
  padding: 8px 18px;
  border-radius: 20px;
  text-decoration: none;
  letter-spacing: .5px;
  transition: opacity .2s, transform .2s;
}
.map-btn:hover { opacity: 0.85; transform: translateY(-1px); }

/* ── FOOTER ── */
.footer {
  text-align: center;
  padding: 40px 24px 60px;
  position: relative;
}

.footer-bubble {
  display: inline-block;
  background: linear-gradient(135deg, var(--purple), var(--pink));
  border-radius: 32px;
  padding: 32px 40px;
  max-width: 500px;
}
.footer-big {
  font-family: 'Boogaloo', cursive;
  font-size: clamp(36px, 10vw, 60px);
  color: var(--yellow);
  line-height: 1;
  margin-bottom: 10px;
}
.footer-small {
  font-size: 15px;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
}

/* ── BALLOONS ── */
.balloons {
  position: fixed;
  pointer-events: none;
  z-index: 0;
  inset: 0;
  overflow: hidden;
}
.balloon {
  position: absolute;
  bottom: -120px;
  border-radius: 50%;
  animation: riseUp linear infinite;
}
@keyframes riseUp {
  0% { transform: translateY(0) rotate(-5deg); opacity: 0.7; }
  50% { transform: translateY(-50vh) rotate(5deg); }
  100% { transform: translateY(-110vh) rotate(-5deg); opacity: 0; }
}

/* ── LANG ── */
[data-lang="fr"] { display: none; }
body.fr [data-lang="en"] { display: none; }
body.fr [data-lang="fr"] { display: revert; }

@media (max-width: 480px) {
  .details-grid { grid-template-columns: 1fr; }
  .detail-card.full { grid-column: 1; }
  .slideshow { max-height: 70vh; }
}
</style>
</head>
<body>

<canvas id="confetti-canvas"></canvas>
<div class="balloons" id="balloons"></div>

<!-- Language -->
<div class="lang-toggle">
  <button class="lang-btn active" onclick="setLang('en')">🇬🇧 EN</button>
  <button class="lang-btn" onclick="setLang('fr')">🇫🇷 FR</button>
</div>

<!-- ── HERO ── -->
<section class="hero">
  <div class="hero-bg"></div>

  <!-- floating shapes -->
  <div class="shape" style="width:300px;height:300px;top:-80px;left:-100px;background:var(--purple);animation-duration:7s;animation-delay:0s;"></div>
  <div class="shape" style="width:200px;height:200px;bottom:-60px;right:-60px;background:var(--pink);animation-duration:9s;animation-delay:2s;"></div>
  <div class="shape" style="width:150px;height:150px;top:40%;left:80%;background:var(--teal);animation-duration:8s;animation-delay:1s;"></div>
  <div class="shape" style="width:100px;height:100px;top:20%;left:5%;background:var(--yellow);animation-duration:6s;animation-delay:3s;"></div>

  <div class="hero-tag" data-lang="en">🎉 You're invited!</div>
  <div class="hero-tag" data-lang="fr">🎉 Tu es invité·e !</div>

  <div class="hero-name">NIV</div>

  <div class="age-ring">
    <div class="age-ring-inner"></div>
    <span class="age-num">9</span>
  </div>

  <div class="hero-sub" data-lang="en">is turning 9 — let's party! 🥳</div>
  <div class="hero-sub" data-lang="fr">fête ses 9 ans — on va s'éclater ! 🥳</div>

  <div class="scroll-hint">
    <span data-lang="en">Scroll</span>
    <span data-lang="fr">Défiler</span>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 10l5 5 5-5"/></svg>
  </div>
</section>

<!-- ── SLIDESHOW ── -->
<section class="slideshow-section">
  <div class="section-label" data-lang="en">⭐ Star of the show</div>
  <div class="section-label" data-lang="fr">⭐ La vedette</div>
  <div class="section-title" data-lang="en">Meet the birthday boy!</div>
  <div class="section-title" data-lang="fr">Voilà le héros du jour !</div>

  <div class="slideshow" id="slideshow">
    <div class="slide active">
      <img src="data:image/jpeg;base64," alt="Niv birthday" />
      <div class="slide-caption" data-lang="en">Birthday vibes 🎂✌️</div>
      <div class="slide-caption" data-lang="fr">Ambiance anniversaire 🎂✌️</div>
    </div>
    <div class="slide">
      <img src="data:image/jpeg;base64," alt="Niv football" />
      <div class="slide-caption" data-lang="en">Future football star ⚽</div>
      <div class="slide-caption" data-lang="fr">Futur champion de foot ⚽</div>
    </div>
    <div class="slide">
      <img src="data:image/jpeg;base64," alt="Niv with dog" />
      <div class="slide-caption" data-lang="en">Best buds 🐺❤️</div>
      <div class="slide-caption" data-lang="fr">Les meilleurs amis 🐺❤️</div>
    </div>
    <div class="slide">
      <img src="data:image/jpeg;base64," alt="Niv family" />
      <div class="slide-caption" data-lang="en">Squad ready ✌️</div>
      <div class="slide-caption" data-lang="fr">La team est prête ✌️</div>
    </div>
    <div class="slide">
      <img src="data:image/jpeg;base64," alt="Niv gaming" />
      <div class="slide-caption" data-lang="en">Level 9 unlocked 🎮</div>
      <div class="slide-caption" data-lang="fr">Niveau 9 débloqué 🎮</div>
    </div>

    <div class="slide-arrows">
      <button class="arrow-btn" onclick="changeSlide(-1)">‹</button>
      <button class="arrow-btn" onclick="changeSlide(1)">›</button>
    </div>
  </div>

  <div class="slide-nav" id="slide-nav">
    <button class="dot active" onclick="goSlide(0)"></button>
    <button class="dot" onclick="goSlide(1)"></button>
    <button class="dot" onclick="goSlide(2)"></button>
    <button class="dot" onclick="goSlide(3)"></button>
    <button class="dot" onclick="goSlide(4)"></button>
  </div>
</section>

<!-- ── PARTY DETAILS ── -->
<section class="details-section">
  <div class="section-label" data-lang="en">📋 The details</div>
  <div class="section-label" data-lang="fr">📋 Les infos</div>
  <div class="section-title" data-lang="en">Party info 🎈</div>
  <div class="section-title" data-lang="fr">Infos fête 🎈</div>

  <div class="details-grid">
    <div class="detail-card accent-pink">
      <div class="detail-icon">📅</div>
      <div class="detail-label pink" data-lang="en">Date</div>
      <div class="detail-label pink" data-lang="fr">Date</div>
      <div class="detail-value big" data-lang="en">Saturday<br>18 April</div>
      <div class="detail-value big" data-lang="fr">Samedi<br>18 avril</div>
    </div>

    <div class="detail-card accent-yellow">
      <div class="detail-icon">⏰</div>
      <div class="detail-label yellow" data-lang="en">Time</div>
      <div class="detail-label yellow" data-lang="fr">Heure</div>
      <div class="detail-value big" data-lang="en">From 3pm 🎉</div>
      <div class="detail-value big" data-lang="fr">Dès 15h 🎉</div>
    </div>

    <div class="detail-card full accent-teal">
      <div class="detail-icon">📍</div>
      <div class="detail-label teal" data-lang="en">Where</div>
      <div class="detail-label teal" data-lang="fr">Où</div>
      <div class="detail-value" style="font-size:18px;margin-bottom:8px;">19 Rue de Belfort<br>94700 Maisons-Alfort, France</div>
      <a class="map-btn" href="https://www.google.com/maps/search/?api=1&query=19+Rue+de+Belfort+94700+Maisons-Alfort" target="_blank">
        <span data-lang="en">📌 Open in Google Maps</span>
        <span data-lang="fr">📌 Voir sur Google Maps</span>
      </a>
    </div>
  </div>
</section>

<!-- ── FOOTER ── -->
<footer class="footer">
  <div class="footer-bubble">
    <div class="footer-big" data-lang="en">See you there! 🥳🎂</div>
    <div class="footer-big" data-lang="fr">On t'attend ! 🥳🎂</div>
    <div class="footer-small" data-lang="en">Come ready to celebrate Niv turning 9! 🎈🎊</div>
    <div class="footer-small" data-lang="fr">Viens fêter les 9 ans de Niv ! 🎈🎊</div>
  </div>
</footer>

<script>
// ── BALLOONS ──
const balloonColors = ['#ff4d8d','#FFE033','#00C9B1','#7B2FBE','#FF7733','#6ec6ff'];
const bc = document.getElementById('balloons');
for (let i = 0; i < 12; i++) {
  const b = document.createElement('div');
  b.className = 'balloon';
  const size = 30 + Math.random() * 50;
  const color = balloonColors[Math.floor(Math.random() * balloonColors.length)];
  b.style.cssText = `
    width:${size}px; height:${size * 1.25}px;
    left:${Math.random() * 100}%;
    background:${color};
    opacity:0.18;
    animation-duration:${10+Math.random()*15}s;
    animation-delay:-${Math.random()*20}s;
    border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
  `;
  bc.appendChild(b);
}

// ── SLIDESHOW ──
let current = 0;
const slides = document.querySelectorAll('.slide');
const dots = document.querySelectorAll('.dot');
let timer = setInterval(() => changeSlide(1), 3500);

function goSlide(n) {
  slides[current].classList.remove('active');
  dots[current].classList.remove('active');
  current = n;
  slides[current].classList.add('active');
  dots[current].classList.add('active');
  clearInterval(timer);
  timer = setInterval(() => changeSlide(1), 3500);
}

function changeSlide(dir) {
  goSlide((current + dir + slides.length) % slides.length);
}

// ── CONFETTI ──
const canvas = document.getElementById('confetti-canvas');
const ctx = canvas.getContext('2d');
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;
window.addEventListener('resize', () => {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
});

const confettiPieces = [];
const colors = ['#ff4d8d','#FFE033','#00C9B1','#7B2FBE','#FF7733','#fff'];

for (let i = 0; i < 80; i++) {
  confettiPieces.push({
    x: Math.random() * canvas.width,
    y: Math.random() * canvas.height - canvas.height,
    w: 6 + Math.random() * 8,
    h: 10 + Math.random() * 6,
    color: colors[Math.floor(Math.random() * colors.length)],
    speed: 1.5 + Math.random() * 2.5,
    angle: Math.random() * Math.PI * 2,
    spin: (Math.random() - 0.5) * 0.15,
    wobble: Math.random() * 2,
    wobbleSpeed: 0.02 + Math.random() * 0.04,
    wobbleT: Math.random() * Math.PI * 2,
  });
}

function animateConfetti() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  confettiPieces.forEach(p => {
    p.y += p.speed;
    p.angle += p.spin;
    p.wobbleT += p.wobbleSpeed;
    p.x += Math.sin(p.wobbleT) * p.wobble;
    if (p.y > canvas.height + 20) {
      p.y = -20; p.x = Math.random() * canvas.width;
    }
    ctx.save();
    ctx.translate(p.x, p.y);
    ctx.rotate(p.angle);
    ctx.fillStyle = p.color;
    ctx.globalAlpha = 0.75;
    ctx.fillRect(-p.w/2, -p.h/2, p.w, p.h);
    ctx.restore();
  });
  requestAnimationFrame(animateConfetti);
}
animateConfetti();

// ── LANG ──
function setLang(lang) {
  document.body.classList.toggle('fr', lang === 'fr');
  document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
  document.querySelector(`.lang-btn[onclick*="${lang}"]`).classList.add('active');
  document.documentElement.lang = lang;
}
</script>
</body>
</html>
